TZ=Asia/Shanghai
HTTP_PORT=8080
# MCP_PORT=8081
LIFELOG_SERVER_PORT=8080
LIFELOG_SERVER_DB_PATH=./data/lifelog.db
LIFELOG_MCP_ENABLED=false
LIFELOG_MCP_PORT=8081
LIFELOG_LOCAL_IMAGE_REPO=lifelog-local
LIFELOG_IMAGE_TAG=main
LIFELOG_IMAGE_PRUNE_UNTIL=168h

